<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- ✅ Forces the dark-mode splash screen to also use your beautiful green background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F4C5C" />
        </shape>
    </item>

    <!-- ✅ Keeps your centered Jibu Kenya logo crisp and visible -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
    
</layer-list>